    handleFeedback: function(messageId, rating) {
      var feedbackDiv = $root.querySelector('.helpjet-feedback[data-message-id="' + messageId + '"]');
      if (!feedbackDiv) return;
      
      // Clear previous selections and highlight current choice
      var buttons = feedbackDiv.querySelectorAll('.helpjet-feedback-btn');
      buttons.forEach(function(btn) {
        btn.classList.remove('selected');
      });
      
      // Highlight the selected button
      var selectedButton = feedbackDiv.querySelector('.helpjet-feedback-btn[data-rating="' + rating + '"]');
      if (selectedButton) {
        selectedButton.classList.add('selected');
      }
      
      // Clear any existing message - don't show message until API responds
      var existingMessage = feedbackDiv.querySelector('.helpjet-feedback-message');
      if (existingMessage) {
        existingMessage.remove();
      }
      
      // Send feedback to API
      var self = this;
      var feedbackUrl = this.config.apiBaseUrl + '/api/feedback';
      console.log('🔧 Feedback URL:', feedbackUrl);
      console.log('Sending feedback:', {
        sessionId: this.getSessionId(),
        rating: rating,
        messageId: messageId
      });
      
      fetch(feedbackUrl, {
        method: 'POST',
        mode: 'cors',
        credentials: 'omit',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          sessionId: this.getSessionId(),
          rating: rating
        })
      })
      .then(function(response) {
        console.log('Feedback API response status:', response.status);
        console.log('Feedback API response headers:', response.headers.get('content-type'));
        
        // Check if response is JSON
        var contentType = response.headers.get('content-type');
        if (contentType && contentType.includes('application/json')) {
          return response.json().then(function(data) {
            console.log('Feedback API response data:', data);
            
            if (response.ok) {
              console.log('✅ Feedback recorded successfully:', rating);
              // Show success message after API confirms
              var feedbackContainer = feedbackDiv.querySelector('.helpjet-feedback-container');
              if (feedbackContainer) {
                var thankYouMessage = document.createElement('span');
                thankYouMessage.className = 'helpjet-feedback-message';
                thankYouMessage.textContent = 'Feedback submitted';
                feedbackContainer.appendChild(thankYouMessage);
                
                // Remove message after 3 seconds
                setTimeout(function() {
                  if (thankYouMessage && thankYouMessage.parentNode) {
                    thankYouMessage.parentNode.removeChild(thankYouMessage);
                  }
                }, 3000);
              }
            } else {
              console.error('❌ Failed to record feedback - HTTP', response.status, ':', data);
              // Show error message
              var feedbackContainer = feedbackDiv.querySelector('.helpjet-feedback-container');
              if (feedbackContainer) {
                var errorMessage = document.createElement('span');
                errorMessage.className = 'helpjet-feedback-message';
                errorMessage.textContent = 'Error recording feedback';
                errorMessage.style.color = '#dc2626';
                feedbackContainer.appendChild(errorMessage);
              }
            }
          });
        } else {
          // Non-JSON response (likely HTML error page)
          return response.text().then(function(text) {
            console.error('❌ Received non-JSON response from feedback API:', text.substring(0, 200) + '...');
            console.error('❌ Full response status:', response.status, response.statusText);
            
            // Show error message
            var feedbackContainer = feedbackDiv.querySelector('.helpjet-feedback-container');
            if (feedbackContainer) {
              var errorMessage = document.createElement('span');
              errorMessage.className = 'helpjet-feedback-message';
              errorMessage.textContent = 'API Error (' + response.status + ')';
              errorMessage.style.color = '#dc2626';
              feedbackContainer.appendChild(errorMessage);
            }
          });
        }
      })
      .catch(function(error) {
        console.error('❌ Network error recording feedback:', error);
        // Show error message
        var feedbackContainer = feedbackDiv.querySelector('.helpjet-feedback-container');
        if (feedbackContainer) {
          var errorMessage = document.createElement('span');
          errorMessage.className = 'helpjet-feedback-message';
          errorMessage.textContent = 'Network error';
          errorMessage.style.color = '#dc2626';
          feedbackContainer.appendChild(errorMessage);
        }
      });
    },
    
    showTypingIndicator: function() {
      var messages = $root.getElementById('helpjet-messages');
      var typingEl = document.createElement('div');
      typingEl.className = 'helpjet-typing-indicator';
      typingEl.id = 'helpjet-typing-indicator';
      typingEl.innerHTML = `
        <div class="helpjet-spinner"></div>
        <div class="helpjet-typing-text">thinking...</div>
      `;
      messages.appendChild(typingEl);
      messages.scrollTop = messages.scrollHeight;
      // Update scroll-to-bottom button visibility
      this.checkScrollToBottomVisibility();
    },
    
    hideTypingIndicator: function() {
      var typingEl = $root.getElementById('helpjet-typing-indicator');
      if (typingEl) {
        typingEl.remove();
      }
    },
    
    resetLoadingState: function() {
      this.isLoading = false;
      var input = $root.getElementById('helpjet-input');
      var send = $root.getElementById('helpjet-send');
      if (input) {
        input.disabled = false;
        this.updateDummyContent();
      }
      if (send) {
        send.disabled = false;
        send.innerHTML = '<svg viewBox="0 0 24 24" style="width: 16px; height: 16px;">' + this.getIconSVG('Send') + '</svg>';
      }
    },
    
    callAPI: function(message) {
      // Show typing indicator with spinner
      this.showTypingIndicator();
      
      // Add user message to conversation history
      this.messages.push({ role: 'user', content: message });
      
      // Use absolute URL to HelpJet server
      var apiUrl = this.config.apiBaseUrl + '/api/chat';
      
      // Handle streaming response like BotPreview
      fetch(apiUrl, {
        method: 'POST',
        mode: 'cors',
        credentials: 'omit',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          messages: this.messages, // Send full conversation history
          chatbotId: 'jh70pt46bs6nw63ctytg09qban84zyex',
          widget: true,
          context: {
            conversationId: this.getSessionId()
          }
        })
      })
      .then(response => {
        if (!response.ok) {
          throw new Error('Network response was not ok: ' + response.status);
        }
        
        // Hide typing indicator immediately when stream starts
        this.hideTypingIndicator();
        
        // Create the bot message element for streaming
        var messageEl = this.createStreamingMessage();
        
        // Handle streaming response
        return this.handleStreamingResponse(response, messageEl);
      })
      .catch(error => {
        console.error('Chat API error:', error);
        // Hide typing indicator
        this.hideTypingIndicator();
        this.addMessage('Sorry, there was an error processing your request.', 'bot');
        this.resetLoadingState();
      });
    },
    
    createStreamingMessage: function() {
      var messages = $root.getElementById('helpjet-messages');
      var messageId = 'msg-' + Date.now() + '-' + Math.random().toString(36).substr(2, 9);
      var messageEl = document.createElement('div');
      messageEl.className = 'helpjet-message bot helpjet-streaming';
      messageEl.setAttribute('data-message-id', messageId);
      messageEl.innerHTML = '<div class="helpjet-message-content"></div>';
      messages.appendChild(messageEl);
      messages.scrollTop = messages.scrollHeight;
      // Update scroll-to-bottom button visibility
      this.checkScrollToBottomVisibility();
      return messageEl;
    },
    
    handleStreamingResponse: function(response, messageEl) {
      var reader = response.body.getReader();
      var decoder = new TextDecoder();
      var content = '';
      var self = this; // Store reference to Widget context
      
      function readStream() {
        return reader.read().then(function(result) {
          if (result.done) {
            console.log('Stream complete. Final content length:', content.length);
            
            // Stream complete, finalize the message
            messageEl.classList.remove('helpjet-streaming');
            if (!content.trim()) {
              console.log('No content received, using fallback message');
              content = 'Sorry, I could not process your request.';
              messageEl.querySelector('.helpjet-message-content').innerHTML = content;
            } else {
              // Debug: Log the raw content before processing
              console.log('Raw content before parseMarkdown:', JSON.stringify(content));
              
              // Now apply full markdown processing to the complete content
              var processedContent = self.parseMarkdown(content);
              
              // Debug: Log the processed content
              console.log('Processed content after parseMarkdown:', processedContent);
              
              messageEl.querySelector('.helpjet-message-content').innerHTML = processedContent;
            }
            
            // Add bot message to conversation history
            self.messages.push({ role: 'assistant', content: content });
            
            // Add feedback buttons for streamed bot responses
            var messages = $root.getElementById('helpjet-messages');
            var messagesCount = messages.querySelectorAll('.helpjet-message.bot').length;
            var messageId = messageEl.getAttribute('data-message-id');
            if (self.config.collectFeedback && messagesCount > 0 && messageId) {
              self.addFeedbackButtons(messageEl, messageId);
            }
            
            self.resetLoadingState();
            return;
          }
          
          var chunk = decoder.decode(result.value, { stream: true });
          
          // Split by newlines but use regular newline characters
          var lines = chunk.split(String.fromCharCode(10));
          
          for (var i = 0; i < lines.length; i++) {
            var line = lines[i].trim();
            
            // Handle different streaming data formats
            if (line.startsWith('0:')) {
              // Text content
              try {
                var textData = line.substring(2);
                var textPart = JSON.parse(textData);
                
                content += textPart;
                // During streaming, only apply basic text formatting to avoid issues with partial content
                var streamingContent = content.replace(/\n/g, '<br>');
                messageEl.querySelector('.helpjet-message-content').innerHTML = streamingContent;
                
                // Auto-scroll
                var messages = $root.getElementById('helpjet-messages');
                messages.scrollTop = messages.scrollHeight;
                // Update scroll-to-bottom button visibility
                self.checkScrollToBottomVisibility();
              } catch (e) {
                console.log('Text parse error:', e, 'for line:', line);
              }
            } else if (line.startsWith('f:')) {
              console.log('Stream started');
            } else if (line.startsWith('9:')) {
              console.log('AI is using tools to search knowledge base...');
              // Tool is being called, keep the stream alive
            } else if (line.startsWith('a:')) {
              console.log('Search complete, generating response...');
              // Tool result received, AI should continue with final response
            } else if (line.startsWith('e:')) {
              try {
                var endData = JSON.parse(line.substring(2));
                console.log('Stream ending with reason:', endData.finishReason);
                // Don't add fallback messages here - let the main completion handler deal with empty content
              } catch (e) {
                console.log('End data parse error:', e);
              }
            } else if (line.startsWith('d:')) {
              console.log('Stream complete');
            }
          }
          
          return readStream();
        }).catch(function(error) {
          console.error('Stream reading error:', error);
          self.resetLoadingState();
          messageEl.classList.remove('helpjet-streaming');
          messageEl.querySelector('.helpjet-message-content').innerHTML = 'Sorry, there was an error processing your request.';
        });
      }
      
      return readStream();
    },
    
    startNewConversation: function() {
      // Clear conversation history and reset with welcome message
      var welcomeMessage = this.config.welcomeMessage || 'Hi! How can I help you today?';
      this.messages = [{ role: 'assistant', content: welcomeMessage }];
      
      // Clear all messages except the welcome message
      var messages = $root.getElementById('helpjet-messages');
      if (messages) {
        messages.innerHTML = `
          <div class="helpjet-message bot">
            <div class="helpjet-message-content">${welcomeMessage}</div>
          </div>
        `;
      }
      
      // Clear input
      var input = $root.getElementById('helpjet-input');
      if (input) {
        input.value = '';
      }
      
      // Update dummy content after clearing input
      this.updateDummyContent();
      
      // Show suggested questions again (reset to initial state)
      var suggestedQuestions = $root.getElementById('helpjet-suggested-questions');
      if (suggestedQuestions) {
        suggestedQuestions.style.display = '';
      }
      
      // Generate new session ID
      var newSessionId = 'session-' + Date.now() + '-' + Math.random().toString(36).substr(2, 9);
      localStorage.setItem('helpjet-session-' + 'jh70pt46bs6nw63ctytg09qban84zyex', newSessionId);
      
      console.log('Started new conversation with session ID:', newSessionId);
    },
    
    getSessionId: function() {
      var sessionId = localStorage.getItem('helpjet-session-' + 'jh70pt46bs6nw63ctytg09qban84zyex');
      if (!sessionId) {
        sessionId = 'session-' + Date.now() + '-' + Math.random().toString(36).substr(2, 9);
        localStorage.setItem('helpjet-session-' + 'jh70pt46bs6nw63ctytg09qban84zyex', sessionId);
      }
      return sessionId;
    }
  };
  
  // Define the custom element. The shadow root isolates widget styles from the host page.
  class HelpJetWidgetElement extends HTMLElement {
    constructor() {
      super();
      $root = this.attachShadow({ mode: 'open' });
    }
    connectedCallback() {
      Widget.init();
    }
  }

  if (!customElements.get('helpjet-widget')) {
    customElements.define('helpjet-widget', HelpJetWidgetElement);
  }

  // Mount the widget when DOM is ready (and targeting rules allow it).
  function mountHelpJet() {
    if (!Widget.shouldShowWidget()) {
      console.log('HelpJet widget hidden due to targeting rules');
      return;
    }
    var el = document.createElement('helpjet-widget');
    document.body.appendChild(el);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', mountHelpJet);
  } else {
    mountHelpJet();
  }

  // Expose API
  window.HelpJet.widget = Widget;

})(window, document);
