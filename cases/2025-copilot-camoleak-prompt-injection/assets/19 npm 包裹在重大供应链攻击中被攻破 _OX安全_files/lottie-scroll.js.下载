class LottieScrollPlayer{constructor(){this.players=[];this.options={root:null,rootMargin:'0px',threshold:0.1};this.init()}
init(){this.observer=new IntersectionObserver((entries)=>{entries.forEach(entry=>{const player=entry.target;if(entry.isIntersecting){player.play()}else{player.stop()}})},this.options);document.querySelectorAll('lottie-player').forEach(player=>{player.removeAttribute('autoplay');this.observer.observe(player)})}}
document.addEventListener('DOMContentLoaded',()=>{new LottieScrollPlayer()})