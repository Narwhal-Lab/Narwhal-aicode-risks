document.addEventListener('DOMContentLoaded',function(){var page=2;var loadMoreButton=document.getElementById('loadMore');if(!loadMoreButton){return}
loadMoreButton.addEventListener('click',function(e){e.preventDefault();fetch(ajax_params.ajax_url,{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded; charset=utf-8'},body:'action=load_more_posts&page='+page}).then(response=>response.text()).then(data=>{if(data){document.getElementById('posts-container').insertAdjacentHTML('beforeend',data);page++}else{loadMoreButton.style.display='none'}}).catch(error=>console.error('Error loading more posts:',error))})})