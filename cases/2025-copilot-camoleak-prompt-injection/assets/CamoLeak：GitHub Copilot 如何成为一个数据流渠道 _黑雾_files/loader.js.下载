    bindEvents: function() {
      var button = $root.getElementById('helpjet-button');
      var chat = $root.getElementById('helpjet-chat');
      var input = $root.getElementById('helpjet-input');
      var dummy = $root.getElementById('helpjet-input-dummy');
      var send = $root.getElementById('helpjet-send');
      
      button.addEventListener('click', this.toggle.bind(this));
      send.addEventListener('click', this.sendMessage.bind(this));
      
      // Handle Enter key behavior for textarea
      input.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey && !Widget.isLoading) {
          e.preventDefault();
          Widget.sendMessage();
        }
      });
      
      // Update dummy div content on input
      input.addEventListener('input', function() {
        Widget.updateDummyContent();
        
        // Hide suggested questions when user starts typing
        var suggestedQuestions = $root.getElementById('helpjet-suggested-questions');
        if (suggestedQuestions && input.value.trim().length > 0) {
          suggestedQuestions.style.display = 'none';
        }
      });
      
      // Initial content sync
      this.updateDummyContent();
      
      // Suggested questions event handling
      var suggestedQuestions = $root.getElementById('helpjet-suggested-questions');
      if (suggestedQuestions) {
        var questionButtons = suggestedQuestions.querySelectorAll('.helpjet-suggested-question');
        for (var i = 0; i < questionButtons.length; i++) {
          questionButtons[i].addEventListener('click', function() {
            var question = this.getAttribute('data-question');
            if (question) {
              // Hide suggested questions after selection
              if (suggestedQuestions) {
                suggestedQuestions.style.display = 'none';
              }
              
              // Send the selected question as a message
              Widget.sendMessageWithText(question);
            }
          });
        }
      }
      
      // Scroll-to-bottom functionality
      var messages = $root.getElementById('helpjet-messages');
      var scrollToBottomBtn = $root.getElementById('helpjet-scroll-to-bottom');
      
      if (messages && scrollToBottomBtn) {
        var self = this;
        
        // Add scroll event listener
        messages.addEventListener('scroll', self.checkScrollToBottomVisibility.bind(self));
        
        // Add click event to scroll to bottom
        scrollToBottomBtn.addEventListener('click', function() {
          messages.scrollTop = messages.scrollHeight;
          self.checkScrollToBottomVisibility();
        });
        
        // Initial check
        self.checkScrollToBottomVisibility();
      }
    },
    
    toggle: function() {
      var chat = $root.getElementById('helpjet-chat');
      this.isOpen = !this.isOpen;
      chat.classList.toggle('open', this.isOpen);
    },
    
    updateDummyContent: function() {
      var input = $root.getElementById('helpjet-input');
      var dummy = $root.getElementById('helpjet-input-dummy');
      
      if (input && dummy) {
        var content = input.value || input.placeholder;
        // Add dummy character to maintain line height
        dummy.textContent = content + '|';
      }
    },
    
    sendMessage: function() {
      var input = $root.getElementById('helpjet-input');
      var send = $root.getElementById('helpjet-send');
      var message = input.value.trim();
      
      if (!message || this.isLoading) return;
      
      // Set loading state
      this.isLoading = true;
      input.disabled = true;
      send.disabled = true;
      send.innerHTML = '<div class="helpjet-spinner" style="width: 16px; height: 16px; border-width: 2px;"></div>';
      
      this.addMessage(message, 'user');
      input.value = '';
      
      // Update dummy content after clearing
      this.updateDummyContent();
      
      // Send to API
      this.callAPI(message);
    },
    
    sendMessageWithText: function(messageText) {
      var input = $root.getElementById('helpjet-input');
      var send = $root.getElementById('helpjet-send');
      
      if (!messageText || this.isLoading) return;
      
      // Set loading state
      this.isLoading = true;
      input.disabled = true;
      send.disabled = true;
      send.innerHTML = '<div class="helpjet-spinner" style="width: 16px; height: 16px; border-width: 2px;"></div>';
      
      this.addMessage(messageText, 'user');
      
      // Clear input and update dummy content
      input.value = '';
      this.updateDummyContent();
      
      // Send to API
      this.callAPI(messageText);
    },
    
    addMessage: function(content, sender) {
      var messages = $root.getElementById('helpjet-messages');
      var messageId = 'msg-' + Date.now() + '-' + Math.random().toString(36).substr(2, 9);
      var messageEl = document.createElement('div');
      messageEl.className = 'helpjet-message ' + sender;
      messageEl.id = messageId;
      messageEl.innerHTML = '<div class="helpjet-message-content"></div>';
      
      // Apply markdown parsing for bot messages
      if (sender === 'bot') {
        var processedContent = this.parseMarkdown(content);
        messageEl.querySelector('.helpjet-message-content').innerHTML = processedContent;
        
        // Add feedback buttons if enabled and this isn't the welcome message
        var messagesCount = messages.querySelectorAll('.helpjet-message.bot').length;
        if (this.config.collectFeedback && messagesCount > 0) {
          this.addFeedbackButtons(messageEl, messageId);
        }
      } else {
        messageEl.querySelector('.helpjet-message-content').textContent = content;
      }
      
      messages.appendChild(messageEl);
      messages.scrollTop = messages.scrollHeight;
      
      // Check scroll-to-bottom button visibility after adding message
      this.checkScrollToBottomVisibility();
    },
    
    checkScrollToBottomVisibility: function() {
      var messages = $root.getElementById('helpjet-messages');
      var scrollToBottomBtn = $root.getElementById('helpjet-scroll-to-bottom');
      
      if (messages && scrollToBottomBtn) {
        var isAtBottom = messages.scrollHeight - messages.clientHeight <= messages.scrollTop + 1;
        if (isAtBottom) {
          scrollToBottomBtn.classList.remove('visible');
        } else {
          scrollToBottomBtn.classList.add('visible');
        }
      }
    },
    
    addFeedbackButtons: function(messageEl, messageId) {
      var messages = $root.getElementById('helpjet-messages');
      
      // Remove any existing feedback buttons first
      var existingFeedback = messages.querySelector('.helpjet-feedback');
      if (existingFeedback) {
        existingFeedback.remove();
      }
      
      var feedbackDiv = document.createElement('div');
      feedbackDiv.innerHTML = this.generateFeedbackHTML(messageId, this.config.showNewConversation);
      
      // Bind click events properly
      var self = this;
      feedbackDiv.addEventListener('click', function(e) {
        if (e.target.closest('.helpjet-feedback-btn')) {
          var button = e.target.closest('.helpjet-feedback-btn');
          var rating = button.getAttribute('data-rating');
          var action = button.getAttribute('data-action');
          var msgId = button.getAttribute('data-message-id');
          
          if (rating && msgId) {
            self.handleFeedback(msgId, rating);
          } else if (action === 'new-conversation') {
            self.startNewConversation();
          }
        }
      });
      
      // Insert feedback buttons after the message element, as a separate element
      messageEl.insertAdjacentElement('afterend', feedbackDiv);
      
      // Auto-scroll to show the feedback buttons
      messages.scrollTop = messages.scrollHeight;
      // Update scroll-to-bottom button visibility
      this.checkScrollToBottomVisibility();
    },
    
